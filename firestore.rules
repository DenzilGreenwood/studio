
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Enhanced helper function to check admin role
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.admin == true;
    }

    // Enhanced helper function to check user role
    function hasRole(role) {
      return request.auth != null && 
             request.auth.token.role == role;
    }

    // Enhanced helper function to check permissions
    function hasPermission(permission) {
      return request.auth != null && 
             request.auth.token.permissions != null &&
             permission in request.auth.token.permissions;
    }

    // Helper function to validate recovery blob structure per v1.1.2 white paper
    function isValidRecoveryBlob(data) {
      return data.keys().hasAll(['encryptedPassphrase', 'salt', 'iv', 'iterations', 'version']) &&
             data.encryptedPassphrase is string &&
             data.salt is string &&
             data.iv is string &&
             data.iterations is number &&
             data.iterations >= 100000 &&  // Enforce minimum PBKDF2 iterations
             data.version is string &&
             data.version == '1.1.2';       // Enforce current white paper version
    }

    // Helper function to validate encryption metadata for user data
    function isValidEncryptionMetadata(data) {
      return data.keys().hasAll(['salt', 'iv', 'version']) &&
             data.salt is string &&
             data.iv is string &&
             data.version is string &&
             data.version == '1.1.2';
    }

    // Helper function to check if data contains only encrypted fields
    function isEncryptedData(data) {
      return data.keys().hasAll(['encryptedData', 'metadata']) &&
             data.encryptedData is string &&
             isValidEncryptionMetadata(data.metadata);
    }

    // Helper function to validate feedback structure per v1.0.0 spec
    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'rating', 'createdAt']) &&
             data.userId is string &&
             data.rating is number &&
             data.rating >= 1 &&
             data.rating <= 5 &&
             data.createdAt is timestamp &&
             // Optional fields validation
             (!data.keys().hasAny(['message']) || data.message is string) &&
             (!data.keys().hasAny(['pageContext']) || data.pageContext is string) &&
             (!data.keys().hasAny(['version']) || data.version is string);
    }

    // Deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // USERS - Basic profile information with enhanced authority
    // Allow users to read, update, create, and delete their own profile
    // Allow admins to read profiles for user management
    match /users/{userId} {
      allow read, update, create, delete: if isOwner(userId);
      allow read: if isAdmin() || hasPermission('read:all:users');
      allow update: if isAdmin() && hasPermission('manage:users');
    }

    // RECOVERY SYSTEM - Zero-Knowledge Recovery Blobs
    // Store encrypted passphrase recovery data following v1.1.2 spec
    match /users/{userId}/recovery/{recoveryId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                    isValidRecoveryBlob(request.resource.data);
      allow update: if isOwner(userId) && 
                    isValidRecoveryBlob(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // ENCRYPTED USER DATA COLLECTIONS
    // All sensitive data must be stored encrypted client-side per v1.1.2
    // Every write operation must contain properly encrypted data
    
    // Sessions - Encrypted conversation and protocol data
    match /users/{userId}/sessions/{sessionId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
                            isEncryptedData(request.resource.data);
      // Admin access for analytics
      allow read: if isAdmin() && hasPermission('read:analytics');
    }

    // Session Reports - Encrypted analysis and insights
    match /users/{userId}/sessionReports/{sessionReportId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
                            isEncryptedData(request.resource.data);
    }

    // Journals - Encrypted personal reflections and entries
    match /users/{userId}/journals/{journalId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
                            isEncryptedData(request.resource.data);
    }

    // Journal Messages - Encrypted journal conversation threads
    match /users/{userId}/journals/{journalId}/messages/{messageId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
                            isEncryptedData(request.resource.data);
    }

    // Session Messages - Encrypted chat messages within sessions
    match /users/{userId}/sessions/{sessionId}/messages/{messageId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
                            isEncryptedData(request.resource.data);
    }

    // Clean Reports - Encrypted processed session summaries
    match /users/{userId}/clean-reports/{reportId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
                            isEncryptedData(request.resource.data);
    }

    // CLARITY MAPS - Encrypted visual thought mapping (root-level collection)
    match /users/{userId}/clarityMaps/{clarityMapId} {
      allow read, delete: if request.auth != null && 
                          resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid &&
                    isEncryptedData(request.resource.data);
      allow update: if request.auth != null && 
                    resource.data.userId == request.auth.uid &&
                    isEncryptedData(request.resource.data);
    }

    // INSIGHT REPORTS - Encrypted analysis reports (root-level collection)
    match /users/{userId}/insightReports/{insightReportId} {
      allow read, delete: if request.auth != null && 
                          resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid &&
                    isEncryptedData(request.resource.data);
      allow update: if request.auth != null && 
                    resource.data.userId == request.auth.uid &&
                    isEncryptedData(request.resource.data);
    }

    // FEEDBACK - User satisfaction and product improvement data
    // Stored unencrypted for analytics while maintaining user privacy
    match /feedback/{feedbackId} {
      allow create: if request.auth != null &&
                    request.resource.data.userId == request.auth.uid &&
                    isValidFeedback(request.resource.data);
      allow delete: if request.auth != null &&
                    resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || hasPermission('read:feedback');
      allow update: if false; // Feedback is immutable once created
    }

    // SYSTEM - Public configuration and user count
    match /system/userCount {
      allow read: if true; // Public read for signup validation
      allow write, create, update: if true; // Server operations during signup
    }

    // ENCRYPTION METADATA - Non-sensitive encryption configuration
    // Stores version info, iteration counts, and other public metadata
    match /system/encryptionConfig {
      allow read: if true; // Public read for client encryption setup
      allow write: if isAdmin() && hasPermission('system:config');
    }

    // This should only be in the session storage on the client side of the app 
    // SESSION KEYS - Encrypted session key storage per v1.1.2
    // Used for sessionStorage XOR encryption during active sessions
    // match /users/{userId}/sessionKeys/{keyId} {
    //  allow read, delete: if isOwner(userId);
    //  allow create, update: if isOwner(userId) && 
    //                        isEncryptedData(request.resource.data);
    //}

    // TRASH SYSTEM - Encrypted deleted items with retention policy
    match /users/{userId}/trash/{itemId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
                            isEncryptedData(request.resource.data) &&
                            request.resource.data.keys().hasAll(['deletedAt', 'originalCollection']) &&
                            request.resource.data.deletedAt is timestamp &&
                            request.resource.data.originalCollection is string;
    }
  }
}
